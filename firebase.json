{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "ske-0004-gms",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "node_modules/**",
      "package.json",
      "package-lock.json",
      "**/*.py",
      "**/*.log",
      "**/*.excalidraw",
      "script_test.js",
      "tmp_html_plan/**",
      "자료실/**",
      "docs/**",
      "wc2026/**",
      "resume_신동민.html",
      "SKE-0004-architecture.*",
      "firestore.rules"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
      },
      {
        "source": "/",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
      },
      {
        "source": "**/*.css",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }]
      },
      {
        "source": "**/*.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }]
      }
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
