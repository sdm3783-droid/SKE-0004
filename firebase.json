{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "predeploy": ["node -e \"const fs=require('fs');const f='wc2026/sw.js';const s=fs.readFileSync(f,'utf8');fs.writeFileSync(f,s.replace(/wc2026-v[0-9A-Za-z-]+/,'wc2026-v'+Date.now()));console.log('SW cache version bumped')\""],
    "public": "wc2026",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/package*.json",
      "**/*.py",
      "**/*.log",
      "**/*.excalidraw",
      "script_test.js",
      "tmp_html_plan/**",
      "handoff/**",
      "자료실/**",
      "docs/**"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "**/*.css",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
        ]
      },
      {
        "source": "**/*.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
        ]
      },
      {
        "source": "/manifest.json",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
        ]
      },
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
