rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 근골격계 메인앱 - 인증 필요
    match /{col}/{doc} {
      allow read, write: if request.auth != null;
    }

    // WC2026 예측방 루트 (GLOBAL 방만)
    match /wc2026_rooms/GLOBAL {
      allow read: if true;
      allow write: if true;

      // 멤버: 닉네임 10자 이하, joinedAt/lastSeen 필드만
      match /members/{nick} {
        allow read: if true;
        allow create: if nick.size() <= 10
                      && request.resource.data.keys().hasOnly(['joinedAt','lastSeen'])
                      && request.resource.data.size() == 2;
        allow update: if nick.size() <= 10
                      && request.resource.data.keys().hasOnly(['joinedAt','lastSeen'])
                      && request.resource.data.size() == 2;
        allow delete: if true;
      }

      // 예측: 닉네임 10자 이하, 최대 150필드 (104경기 + 여유)
      match /predictions/{nick} {
        allow read: if true;
        allow create, update: if nick.size() <= 10
                              && request.resource.data.size() <= 150;
        allow delete: if true;
      }

      // 채팅: 읽기 공개, 쓰기는 nick/msg/ts 필드만 허용
      match /chat/{msgId} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasOnly(['nick','msg','ts'])
                      && request.resource.data.nick is string
                      && request.resource.data.nick.size() <= 10
                      && request.resource.data.msg is string
                      && request.resource.data.msg.size() <= 100;
        allow delete: if false;
      }

      // 반응: 읽기/쓰기 공개 (arrayUnion/arrayRemove 사용)
      match /rxns/{matchKey} {
        allow read: if true;
        allow write: if true;
      }
    }
  }
}
